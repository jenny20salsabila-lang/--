func tambahMahasiswa() {
	if jumlahMahasiswa >= NMAX_MAHASISWA {
		fmt.Println("Data mahasiswa sudah penuh!")
		return
	}

	fmt.Println("\n  -- FORM PENDAFTARAN MAHASISWA --")
	tampilkanDaftarJurusanRingkas()

	fmt.Println()

	nomor := generateNomorPendaftaran()
	fmt.Printf("  No. Pendaftaran  : %s\n", nomor)

	nama := inputString("  Nama Lengkap     : ")
	kode := inputString("  Kode Jurusan     : ")
	idxJ := cariJurusan(kode)
	if idxJ == -1 {
		fmt.Println("Kode jurusan tidak ditemukan!")
		return
	}
	nilai, ok := inputNilai("  Nilai Tes (0-100): ")
	if !ok {
		fmt.Println("Nilai tidak valid.")
		return
	}

	status := hitungStatus(nilai, daftarJurusan[idxJ].Kapasitas, kode)
	daftarMahasiswa[jumlahMahasiswa] = Mahasiswa{nomor, nama, kode, nilai, status}
	jumlahMahasiswa++

	fmt.Printf("\n  %s berhasil didaftarkan! (No. Pendaftaran: %s)\n", nama, nomor)
	if status == "Diterima" {
		fmt.Printf("  Status: DITERIMA  (%.2f >= 60, kuota tersedia)\n", nilai)
	} else if nilai < 60 {
		fmt.Printf("  Status: DITOLAK   (%.2f < 60, tidak memenuhi syarat)\n", nilai)
	} else {
		fmt.Printf("  Status: DITOLAK   (%.2f >= 60, kuota jurusan penuh)\n", nilai)
	}
}

