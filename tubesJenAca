func tampilkanMahasiswaPerJurusan() {
	fmt.Println("\n  -- TAMPILKAN MAHASISWA PER JURUSAN --")
	tampilkanDaftarJurusanRingkas()
	fmt.Println()
	kode := inputString("  Kode Jurusan : ")
	idx := cariJurusan(kode)
	if idx == -1 {
		fmt.Println("Jurusan tidak ditemukan.")
		return
	}

	diterima := hitungJumlahDiterima(kode)
	fmt.Printf("\n  Jurusan  : %s - %s\n", kode, daftarJurusan[idx].NamaJurusan)
	fmt.Printf("  Kuota    : %d  |  Terisi: %d\n", daftarJurusan[idx].Kapasitas, diterima)

	var arrDiterima, arrDitolak, arrPending TabMahasiswa
	nD, nT, nP := 0, 0, 0
	i := 0
	for i < jumlahMahasiswa {
		m := daftarMahasiswa[i]
		if m.KodeJurusan == kode {
			if m.Status == "Diterima" {
				arrDiterima[nD] = m
				nD++
			} else if m.Status == "Ditolak" {
				arrDitolak[nT] = m
				nT++
			} else {
				arrPending[nP] = m
				nP++
			}
		}
		i++
	}

	fmt.Println("\n  DITERIMA")
	cetakTabelMahasiswa(arrDiterima, nD)
	fmt.Println("\n  DITOLAK")
	cetakTabelMahasiswa(arrDitolak, nT)
	fmt.Println("\n  PENDING (belum ada nilai)")
	cetakTabelMahasiswa(arrPending, nP)
}

func editNilaiTes() {
	fmt.Println("\n  -- EDIT NILAI TES --")
	nomor := inputString("  No. Pendaftaran   : ")
	idx := cariMahasiswaSeq(nomor)
	if idx == -1 {
		fmt.Println("Mahasiswa tidak ditemukan.")
		return
	}
	fmt.Printf("  Nilai saat ini    : %.2f\n", daftarMahasiswa[idx].NilaiTes)
	nilai, ok := inputNilai("  Nilai baru        : ")
	if !ok {
		fmt.Println("Nilai tidak valid.")
		return
	}
	daftarMahasiswa[idx].NilaiTes = nilai
	idxJ := cariJurusan(daftarMahasiswa[idx].KodeJurusan)
	if idxJ != -1 {
		daftarMahasiswa[idx].Status = hitungStatus(nilai, daftarJurusan[idxJ].Kapasitas, daftarMahasiswa[idx].KodeJurusan)
	}
	fmt.Printf("  Nilai diubah. Status sekarang: %s\n", daftarMahasiswa[idx].Status)
}

func hapusNilaiTes() {
	fmt.Println("\n  -- HAPUS NILAI TES --")
	nomor := inputString("  No. Pendaftaran : ")
	idx := cariMahasiswaSeq(nomor)
	if idx == -1 {
		fmt.Println("Mahasiswa tidak ditemukan.")
		return
	}
	daftarMahasiswa[idx].NilaiTes = 0
	daftarMahasiswa[idx].Status = "Pending"
	fmt.Println("  Nilai dihapus. Status kembali: Pending")
}

func tampilkanTerurut() {
	if jumlahMahasiswa == 0 {
		fmt.Println("Belum ada data mahasiswa.")
		return
	}
	fmt.Println("\n  -- TAMPILKAN DATA TERURUT --")
	fmt.Println("  1. Nilai Tes       (Selection Sort)")
	fmt.Println("  2. Jurusan         (Selection Sort)")
	fmt.Println("  3. Nama Mahasiswa  (Insertion Sort)")
	pilihan := inputMenu("  Pilihan : ")

	var arrLokal TabMahasiswa
	i := 0
	for i < jumlahMahasiswa {
		arrLokal[i] = daftarMahasiswa[i]
		i++
	}

	label := ""
	ascending := true

	if pilihan == 1 {
		ascending = pilihUrutan("Nilai Tes")
		selectionSortByNilai(&arrLokal, jumlahMahasiswa, ascending)
		label = "NILAI TES"
	} else if pilihan == 2 {
		ascending = pilihUrutan("Jurusan")
		selectionSortByJurusan(&arrLokal, jumlahMahasiswa, ascending)
		label = "JURUSAN"
	} else if pilihan == 3 {
		ascending = pilihUrutan("Nama")
		insertionSortByNama(&arrLokal, jumlahMahasiswa, ascending)
		label = "NAMA"
	} else {
		fmt.Println("Pilihan tidak valid.")
		return
	}

	urutan := "Ascending"
	if !ascending {
		urutan = "Descending"
	}
	fmt.Printf("\n  Urut berdasarkan %s (%s)\n", label, urutan)
	cetakTabelMahasiswa(arrLokal, jumlahMahasiswa)
} 

func cariMahasiswa() {
	fmt.Println("\n  -- CARI MAHASISWA --")
	fmt.Println("  1. Sequential Search")
	fmt.Println("  2. Binary Search")
	pilihan := inputMenu("  Pilihan : ")
	if pilihan != 1 && pilihan != 2 {
		fmt.Println("Pilihan tidak valid.")
		return
	}
	nomor := inputString("  No. Pendaftaran yang dicari : ")

	idx := -1
	if pilihan == 1 {
		idx = cariMahasiswaSeq(nomor)
	} else {
		idx = cariMahasiswaBin(nomor)
	}

	if idx == -1 {
		fmt.Println("Mahasiswa tidak ditemukan.")
		return
	}

	m := daftarMahasiswa[idx]
	idxJ := cariJurusan(m.KodeJurusan)
	namaJurusan := m.KodeJurusan
	if idxJ != -1 {
		namaJurusan = daftarJurusan[idxJ].NamaJurusan
	}
	fmt.Println("\n  Data mahasiswa ditemukan:")
	garis(42)
	fmt.Printf("  No. Pendaftaran : %s\n", m.NomorPendaftaran)
	fmt.Printf("  Nama            : %s\n", m.Nama)
	fmt.Printf("  Jurusan         : %s - %s\n", m.KodeJurusan, namaJurusan)
	fmt.Printf("  Nilai           : %.2f\n", m.NilaiTes)
	fmt.Printf("  Status          : %s\n", m.Status)
	garis(42)
}

