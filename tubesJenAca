func tambahJurusan() {
	if jumlahJurusan >= NMAX_JURUSAN {
		fmt.Println("Data jurusan sudah penuh!")
		return
	}
	fmt.Println("\n  -- TAMBAH JURUSAN --")
	kode := inputString("  Kode Jurusan : ")
	if cariJurusan(kode) != -1 {
		fmt.Println("Kode jurusan sudah ada!")
		return
	}
	nama := inputString("  Nama Jurusan : ")
	kapasitas, ok := inputKapasitas("  Kapasitas    : ")
	if !ok {
		fmt.Println("Kapasitas tidak valid.")
		return
	}
	daftarJurusan[jumlahJurusan] = Jurusan{kode, nama, kapasitas}
	jumlahJurusan++
	fmt.Println("Jurusan berhasil ditambahkan!")
}

