package main

import (
	"bufio"
	"fmt"
	"os"
	"strconv"
	"strings"
)

type Jurusan struct {
	KodeJurusan string
	NamaJurusan string
	Kapasitas   int
}

type Mahasiswa struct {
	NomorPendaftaran string
	Nama             string
	KodeJurusan      string
	NilaiTes         float64
	Status           string
}

const NMAX_JURUSAN = 20
const NMAX_MAHASISWA = 100

type TabJurusan [NMAX_JURUSAN]Jurusan
type TabMahasiswa [NMAX_MAHASISWA]Mahasiswa

var (
	daftarJurusan   TabJurusan
	jumlahJurusan   int
	daftarMahasiswa TabMahasiswa
	jumlahMahasiswa int
	counterPendaftaran  int
)

var reader = bufio.NewReader(os.Stdin)

func inputString(prompt string) string {
	fmt.Print(prompt)
	s, _ := reader.ReadString('\n')
	return strings.TrimSpace(s)
}
  
func inputKapasitas(prompt string) (int, bool) {
	fmt.Print(prompt)
	s, _ := reader.ReadString('\n')
	s = strings.TrimSpace(s)
	n, err := strconv.Atoi(s)
	if err != nil {
		return 0, false
	}
	return n, true
}

func inputNilai(prompt string) (float64, bool) {
	fmt.Print(prompt)
	s, _ := reader.ReadString('\n')
	s = strings.TrimSpace(s)
	f, err := strconv.ParseFloat(s, 64)
	if err != nil {
		return 0, false
	}
	return f, true
}

func inputMenu(prompt string) int {
	fmt.Print(prompt)
	s, _ := reader.ReadString('\n')
	s = strings.TrimSpace(s)
	n, err := strconv.Atoi(s)
	if err != nil {
		fmt.Println("Input tidak valid, harap masukkan angka.")
		return -99
	}
	return n
}

func generateNomorPendaftaran() string {
	counterPendaftaran++
	return fmt.Sprintf("%02d", counterPendaftaran)
}

func cariJurusan(kode string) int {
	idx := -1
	i := 0
	for i < jumlahJurusan && idx == -1 {
		if daftarJurusan[i].KodeJurusan == kode {
			idx = i
		}
		i++
	}
	return idx
}

func cariMahasiswaSeq(nomor string) int {
	idx := -1
	i := 0
	for i < jumlahMahasiswa && idx == -1 {
		if daftarMahasiswa[i].NomorPendaftaran == nomor {
			idx = i
		}
		i++
	}
	return idx
}

func cariMahasiswaBin(nomor string) int {
	lo := 0
	hi := jumlahMahasiswa - 1
	hasil := -1
	for lo <= hi && hasil == -1 {
		mid := (lo + hi) / 2
		if daftarMahasiswa[mid].NomorPendaftaran == nomor {
			hasil = mid
		} else if daftarMahasiswa[mid].NomorPendaftaran < nomor {
			lo = mid + 1
		} else {
			hi = mid - 1
		}
	}
	return hasil
}

func insertionSortByNomor(arr *TabMahasiswa, n int, ascending bool) {
	i := 1
	for i < n {
		kunci := arr[i]
		j := i - 1
		for j >= 0 {
			harusGeser := false
			if ascending {
				harusGeser = arr[j].NomorPendaftaran > kunci.NomorPendaftaran
			} else {
				harusGeser = arr[j].NomorPendaftaran < kunci.NomorPendaftaran
			}
			if harusGeser {
				arr[j+1] = arr[j]
				j--
			} else {
				j = -1
			}
		}
		arr[j+1] = kunci
		i++
	}
}

func selectionSortByNilai(arr *TabMahasiswa, n int, ascending bool) {
	i := 0
	for i < n-1 {
		idx := i
		j := i + 1
		for j < n {
			lebihKecil := arr[j].NilaiTes < arr[idx].NilaiTes
			lebihBesar := arr[j].NilaiTes > arr[idx].NilaiTes
			if (ascending && lebihKecil) || (!ascending && lebihBesar) {
				idx = j
			}
			j++
		}
		if idx != i {
			arr[i], arr[idx] = arr[idx], arr[i]
		}
		i++
	}
}

func selectionSortByJurusan(arr *TabMahasiswa, n int, ascending bool) {
	i := 0
	for i < n-1 {
		idx := i
		j := i + 1
		for j < n {
			lebihKecil := arr[j].KodeJurusan < arr[idx].KodeJurusan
			lebihBesar := arr[j].KodeJurusan > arr[idx].KodeJurusan
			if (ascending && lebihKecil) || (!ascending && lebihBesar) {
				idx = j
			}
			j++
		}
		if idx != i {
			arr[i], arr[idx] = arr[idx], arr[i]
		}
		i++
	}
}

func insertionSortByNama(arr *TabMahasiswa, n int, ascending bool) {
	i := 1
	for i < n {
		kunci := arr[i]
		j := i - 1
		for j >= 0 {
			harusGeser := false
			if ascending {
				harusGeser = arr[j].Nama > kunci.Nama
			} else {
				harusGeser = arr[j].Nama < kunci.Nama
			}
			if harusGeser {
				arr[j+1] = arr[j]
				j--
			} else {
				j = -1
			}
		}
		arr[j+1] = kunci
		i++
	}
}

func hitungJumlahDiterima(kode string) int {
	jumlah := 0
	i := 0
	for i < jumlahMahasiswa {
		if daftarMahasiswa[i].KodeJurusan == kode && daftarMahasiswa[i].Status == "Diterima" {
			jumlah++
		}
		i++
	}
	return jumlah
}

func hitungStatus(nilai float64, kapasitas int, kode string) string {
	status := "Ditolak"
	if nilai >= 60 && hitungJumlahDiterima(kode) < kapasitas {
		status = "Diterima"
	}
	return status
}

